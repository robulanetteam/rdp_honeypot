# Часовой пояс контейнера
TZ=Europe/Moscow

# Имитируемая Windows-машина
HONEYPOT_COMPUTER=WIN-SRV2008
HONEYPOT_DOMAIN=CORP
HONEYPOT_DNS_COMPUTER=WIN-SRV2008.corp.local
HONEYPOT_DNS_DOMAIN=corp.local

# 1 = форсировать downgrade на legacy RDP (plaintext пароли)
# 0 = принимать NLA и ловить только NetNTLMv2 hash для hashcat
HONEYPOT_FORCE_LEGACY=1

# Публичный лог: каждая N-я попытка с IP пишется в ./data/public/<имя файла>
# Раздавайте ./data/public через nginx/caddy/любой HTTP-сервер
PUBLIC_LOG_NAME=rdp_honeypot.txt
PUBLIC_LOG_EVERY_N=3
WINDOW_HOURS=24

# GeoIP (опционально): скачать базы с зеркала:
#   ./scripts/download_geoip.sh
# Файлы будут помещены в ./data/geoip/ и смонтированы в контейнер автоматически.

# Telegram уведомления (опционально):
# 1. Создайте бота через @BotFather → получите BOT_TOKEN
# 2. Напишите боту /start, узнайте CHAT_ID через @userinfobot или API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
