# Куда писать публичный лог (видим через https://update.edvels.com/<file>)
MIRROR_DIR=/srv/http/update
PUBLIC_LOG_NAME=rdp_honeypot.txt

# Приватный лог с парами логин/пароль (НЕ публикуется)
PRIVATE_LOG=/var/log/rdp_honeypot_credentials.log

# Каждая N-я попытка подключения пишется в публичный лог
PUBLIC_LOG_EVERY_N=3

# Окно учёта попыток (часов)
WINDOW_HOURS=24

# Rate limit (попыток новых соединений в минуту с одного IP)
RATE_LIMIT_PER_MIN=5

# Гибридный режим: если 1, при запросе NLA (CredSSP/HYBRID) отвечаем
# SSL_NOT_ALLOWED_BY_SERVER, провоцируя клиента/бота на retry без NLA.
# В legacy-ветке ловим plaintext-пароли. Если 0 — принимаем NLA и ловим
# только NetNTLMv2 hash.
HONEYPOT_FORCE_LEGACY=1
